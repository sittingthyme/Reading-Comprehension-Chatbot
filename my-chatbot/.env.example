# Copy to .env for local dev if you want non-defaults.
# Production static hosts: set these in the build environment (Vite inlines them at build time).

# Public URL of the Django API (no trailing slash). Required for production builds.
# Example: https://reading-chatbot-api.onrender.com
VITE_API_URL=http://localhost:8000

# Study flow: set to "false" only if you want the legacy non-study UI.
# VITE_STUDY_GATING=false
