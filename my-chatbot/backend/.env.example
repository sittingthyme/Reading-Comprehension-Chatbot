# Copy to .env for local development (never commit .env).
# In production, set these in your host’s environment / secrets manager.

# --- Core Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Leave unset for local SQLite. In production, use your provider’s Postgres URL.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Some hosts require SSL to the database:
# DATABASE_SSL_REQUIRE=true

# --- CORS / CSRF (production: use your real frontend origin(s), comma-separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional HTTPS redirect when DEBUG=False ---
# SECURE_SSL_REDIRECT=true

# --- OpenAI (chat) ---
OPENAI_API_KEY=

# --- Study gating (comma-separated enrollment codes per arm) ---
STUDY_CODES_PERSONALIZED=DEV-PERSONALIZED
STUDY_CODES_GENERIC=DEV-GENERIC
STUDY_START_DATE=2020-01-01
STUDY_TIMEZONE=UTC
STUDY_TOTAL_WEEKS=8

# --- Return login (login code + PIN) ---
STUDY_PIN_MIN_LENGTH=4
STUDY_PIN_MAX_LENGTH=6
STUDY_LOGIN_CODE_LENGTH=10
STUDY_ROTATE_TOKEN_ON_LOGIN=true
